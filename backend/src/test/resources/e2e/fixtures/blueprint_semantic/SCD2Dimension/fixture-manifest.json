{
  "blueprintKey": "SCD2Dimension",
  "semanticPackVersion": "0.1.0",
  "promotionEligible": false,
  "businessScenario": "Verify a draft SCD2Dimension semantic pack records tier history windows across two customer snapshots while keeping later history-window hardening scoped and reviewable.",
  "scopeClassifications": {
    "negativeScope": true,
    "edgeScope": true,
    "failureScope": true,
    "statefulScope": true
  },
  "inputFiles": [
    {
      "path": "input/expectations/scd2-config.json",
      "caseType": "expectation",
      "schemaRef": "scd2_config_v1",
      "rowCount": 1,
      "sha256": "53767a8cfd790cd9b26fcfd02b9a61479f077e491f2106e373627a99b0408875"
    },
    {
      "path": "input/negative/invalid-scd2-config.json",
      "caseType": "negative",
      "schemaRef": "scd2_config_v1",
      "rowCount": 1,
      "sha256": "7de8bc8104d6f41dae683e5d350fbf49aaf66deb1e8ba50b6f6e2e494e4fdcc6"
    },
    {
      "path": "input/run1/customer_tier_day1.csv",
      "caseType": "run1",
      "schemaRef": "scd2_customer_snapshot_csv_v1",
      "rowCount": 2,
      "sha256": "7bb68d2cc333f34ff663bd9422f3d74c7dcde0848213ca56b75b7d75ef6b0622"
    },
    {
      "path": "input/run2/customer_tier_day2.csv",
      "caseType": "run2",
      "schemaRef": "scd2_customer_snapshot_csv_v1",
      "rowCount": 3,
      "sha256": "214c0a91104e4d36d361f42cf6f135efd7c943b671aae7756d55584275357d21"
    }
  ],
  "schemas": [
    {
      "schemaId": "scd2_customer_snapshot_csv_v1",
      "columns": [
        {
          "name": "customer_id",
          "type": "string",
          "nullable": false
        },
        {
          "name": "tier",
          "type": "string",
          "nullable": false
        },
        {
          "name": "effective_date",
          "type": "date",
          "nullable": false
        }
      ]
    },
    {
      "schemaId": "scd2_config_v1",
      "columns": [
        {
          "name": "businessKey",
          "type": "string",
          "nullable": false
        },
        {
          "name": "trackedColumns",
          "type": "json",
          "nullable": false
        },
        {
          "name": "effectiveDateColumn",
          "type": "string",
          "nullable": false
        },
        {
          "name": "expectedFailureCode",
          "type": "string",
          "nullable": true
        }
      ]
    }
  ],
  "positiveCases": [
    {
      "caseId": "customer-tier-history-window-generated",
      "inputRefs": [
        "input/run1/customer_tier_day1.csv",
        "input/run2/customer_tier_day2.csv",
        "input/expectations/scd2-config.json"
      ],
      "expectedOutputRefs": [
        "expected/history-output.csv",
        "expected/history-report.json"
      ],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "C1 closes the SILVER row and opens a GOLD row",
        "C3 appears as a new current row"
      ]
    }
  ],
  "negativeCases": [
    {
      "caseId": "missing-business-key-rejected",
      "inputRefs": [
        "input/negative/invalid-scd2-config.json"
      ],
      "expectedOutputRefs": [],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "expectedFailureCode equals MISSING_BUSINESS_KEY"
      ]
    }
  ],
  "edgeCases": [
    {
      "caseId": "unchanged-customer-remains-single-current-row",
      "inputRefs": [
        "input/run1/customer_tier_day1.csv",
        "input/run2/customer_tier_day2.csv",
        "input/expectations/scd2-config.json"
      ],
      "expectedOutputRefs": [
        "expected/history-output.csv"
      ],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "C2 remains a single open GOLD row despite appearing in both snapshots"
      ]
    }
  ],
  "failureCases": [
    {
      "caseId": "draft-missing-business-key-placeholder",
      "inputRefs": [
        "input/negative/invalid-scd2-config.json"
      ],
      "expectedOutputRefs": [],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "invalid SCD2 config remains reserved for future failure-path proofing"
      ]
    }
  ],
  "multiRunCases": [
    {
      "caseId": "day1-snapshot-then-day2-change",
      "runs": [
        {
          "runId": "day1-seed",
          "inputRefs": [
            "input/run1/customer_tier_day1.csv",
            "input/expectations/scd2-config.json"
          ]
        },
        {
          "runId": "day2-change",
          "inputRefs": [
            "input/run2/customer_tier_day2.csv",
            "input/expectations/scd2-config.json"
          ],
          "expectedOutputRefs": [
            "expected/history-output.csv"
          ],
          "expectedMetricRefs": [
            "expected/expected-metrics.json"
          ]
        }
      ],
      "assertions": [
        "history-output.csv captures non-overlapping effective windows after the second run"
      ]
    }
  ],
  "expectedOutputs": [
    {
      "path": "expected/history-output.csv",
      "format": "csv",
      "comparatorType": "history_window",
      "sha256": "5be4917e0a8a4a495854c5006526c78bd0ec1df644b006ce457a7b0db3e3de90"
    },
    {
      "path": "expected/history-report.json",
      "format": "json",
      "comparatorType": "history_window",
      "sha256": "b26f2f31723fca973800a90c91634b8abf2d7f21b32b7424a58d6e80ecdbb638"
    }
  ],
  "expectedMetrics": [
    {
      "metricId": "history_row_count",
      "path": "expected/expected-metrics.json",
      "format": "json",
      "valueType": "integer",
      "expectedValue": 4,
      "comparatorType": "aggregate_exact",
      "sha256": "d7c885af0f6fa52092d0f4ba85af2e6c5791a9a73cca6834874ee31bc7834a34"
    }
  ],
  "comparator": {
    "type": "history_window",
    "ownerClass": "com.pulse.e2e.semantic.SCD2DimensionSemanticPackValidator",
    "configPath": "comparator-config.json",
    "tolerance": 0
  },
  "caseExemptions": [],
  "promotionCriteria": []
}
