  "positiveCases": [
    {
      "caseId": "cdc-applies-insert-update-delete",
      "inputRefs": [
        "input/run1/account_snapshot.csv",
        "input/run2/cdc_events.csv",
        "input/expectations/merge-config.json"
      ],
      "expectedOutputRefs": [
        "expected/final-state.csv",
        "expected/merge-report.json"
      ],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "A2 updates balance to 275.00",
        "A3 is deleted from the final snapshot",
        "A4 is inserted into the final snapshot"
      ]
    }
  ],
  "negativeCases": [
    {
      "caseId": "unsupported-cdc-operation-rejected",
      "inputRefs": [
        "input/negative/invalid-merge-event.json"
      ],
      "expectedOutputRefs": [],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "expectedFailureCode equals INVALID_MERGE_OPERATION"
      ]
    }
  ],
  "edgeCases": [
    {
      "caseId": "delete-removes-existing-row-on-second-run",
      "inputRefs": [
        "input/run1/account_snapshot.csv",
        "input/run2/cdc_events.csv",
        "input/expectations/merge-config.json"
      ],
      "expectedOutputRefs": [
        "expected/final-state.csv"
      ],
      "expectedMetricRefs": [
        "expected/expected-metrics.json"
      ],
      "assertions": [
        "A3 delete event removes the row without disturbing A1"
      ]
    }
  ],
  "failureCases": [
