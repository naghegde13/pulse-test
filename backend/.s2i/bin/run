#!/usr/bin/env bash
set -euo pipefail

# Runtime image should use the jar staged by assemble.
jar_path="/deployments/app.jar"
if [ ! -f "${jar_path}" ]; then
  # Fallback for local/dev invocations where /deployments is not present.
  jar_path="$(find build/libs -maxdepth 1 -type f -name '*.jar' ! -name '*-plain.jar' | head -n 1 || true)"
fi
if [ -z "${jar_path}" ] || [ ! -f "${jar_path}" ]; then
  echo "No runnable jar found (/deployments/app.jar or build/libs/*.jar)" >&2
  exit 1
fi

exec java ${JAVA_OPTS:-} \
  --add-opens=java.base/sun.nio.ch=ALL-UNNAMED \
  --add-opens=java.base/java.nio=ALL-UNNAMED \
  --add-opens=java.base/java.lang=ALL-UNNAMED \
  --add-opens=java.base/java.util=ALL-UNNAMED \
  -jar "${jar_path}"