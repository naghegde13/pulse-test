#!/usr/bin/env bash
set -euo pipefail

export HOME="${HOME:-/tmp}"
export GRADLE_USER_HOME="${GRADLE_USER_HOME:-/tmp/gradle}"

# Custom S2I scripts are not guaranteed to start in the source tree.
cd "${S2I_SOURCE_DIR:-/tmp/src}"

chmod +x ./gradlew

if command -v timeout >/dev/null 2>&1; then
	set +e
	timeout --signal=TERM 20m ./gradlew --no-daemon --info --stacktrace bootJar -x test
	rc=$?
	set -e

	if [ "$rc" -eq 124 ] || [ "$rc" -eq 137 ]; then
		echo "Gradle bootJar timed out after 20m; collecting JVM diagnostics..."
		if command -v jps >/dev/null 2>&1; then
			jps -l || true
			gradle_pid="$(jps -l | awk '/GradleDaemon|org\.gradle|GradleMain/ {print $1; exit}')"
			if [ -n "$gradle_pid" ] && command -v jcmd >/dev/null 2>&1; then
				jcmd "$gradle_pid" Thread.print || true
			fi
		fi
		exit 124
	fi

	exit "$rc"
else
	./gradlew --no-daemon --info --stacktrace bootJar -x test
fi