#!/usr/bin/env bash
set -euo pipefail

export HOME="${HOME:-/home/default}"
export GRADLE_USER_HOME="${GRADLE_USER_HOME:-${HOME}/.gradle}"

# Custom S2I scripts are not guaranteed to start in the source tree.
cd "${S2I_SOURCE_DIR:-/tmp/src}"

chmod +x ./gradlew

mkdir -p "${GRADLE_USER_HOME}" "${GRADLE_USER_HOME}/project-cache"

# This dependency graph is large (Spark + cloud SDK). Allocate more heap and
# avoid project cache churn in /tmp/src/.gradle to reduce post-compile stalls.
GRADLE_JVM_ARGS="-Xms512m -Xmx2048m -XX:MaxMetaspaceSize=512m -Dfile.encoding=UTF-8"
GRADLE_ARGS=(
	--no-daemon
	--info
	--stacktrace
	-Dorg.gradle.jvmargs="${GRADLE_JVM_ARGS}"
	-Dorg.gradle.projectcachedir="${GRADLE_USER_HOME}/project-cache"
	-Dorg.gradle.vfs.watch=false
	-Dorg.gradle.workers.max=1
	bootJar
	-x
	test
)

./gradlew "${GRADLE_ARGS[@]}" &
gradle_pid=$!
timeout_seconds=1200
deadline=$((SECONDS + timeout_seconds))

while kill -0 "${gradle_pid}" 2>/dev/null; do
	if (( SECONDS >= deadline )); then
		echo "Gradle bootJar timed out after 20m; collecting JVM diagnostics..."
		if command -v jps >/dev/null 2>&1; then
			jps -l || true
			jcmd_pid="$(jps -l | awk '/GradleDaemon|org\.gradle|GradleMain/ {print $1; exit}')"
			if [ -n "${jcmd_pid}" ] && command -v jcmd >/dev/null 2>&1; then
				jcmd "${jcmd_pid}" Thread.print || true
			fi
		fi

		kill -TERM "${gradle_pid}" 2>/dev/null || true
		sleep 5
		kill -KILL "${gradle_pid}" 2>/dev/null || true

		set +e
		wait "${gradle_pid}" 2>/dev/null
		set -e
		exit 124
	fi

	sleep 5
done

set +e
wait "${gradle_pid}"
rc=$?
set -e

if [ "${rc}" -ne 0 ]; then
	exit "${rc}"
fi

# Custom assemble overrides the image default behavior, so explicitly stage
# the runnable jar where run-java.sh expects it.
boot_jar="$(find build/libs -maxdepth 1 -type f -name '*.jar' ! -name '*-plain.jar' | head -n 1 || true)"
if [ -z "${boot_jar}" ]; then
	echo "No boot jar found under build/libs after successful Gradle run."
	exit 1
fi

mkdir -p /deployments
cp "${boot_jar}" /deployments/app.jar
chmod g+rwX /deployments /deployments/app.jar || true
echo "Staged runnable jar: ${boot_jar} -> /deployments/app.jar"

exit "${rc}"